{
  "name": "unsane",
  "version": "0.0.19",
  "description": "A tiny, zero-dependency, run-anywhere HTML sanitization library written in TypeScript.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "!dist/test"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "npm run clean && tsc",
    "test": "vitest run --coverage",
    "test:mutation": "stryker run",
    "test:browser": "npm run build && playwright test",
    "test:update-html5lib": "node scripts/update-html5lib-corpus.mjs",
    "lint": "eslint . --ext .ts,.js",
    "prepare": "npm run build",
    "clean": "rm -rf dist",
    "analyze-size": "tsx measure-size.ts",
    "benchmark": "node benchmarks/sanitize.mjs --check",
    "benchmark:json": "node benchmarks/sanitize.mjs --json",
    "smoke:package": "node scripts/package-smoke-test.mjs",
    "release:notes": "node scripts/release-notes.mjs",
    "verify:release": "node scripts/post-release-verify.mjs",
    "release": "bin/release.sh"
  },
  "keywords": [
    "html",
    "sanitization",
    "security",
    "typescript"
  ],
  "author": "mpopv <mattpopovich@outlook.com> (https://github.com/mpopv)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mpopv/unsane.git"
  },
  "bugs": {
    "url": "https://github.com/mpopv/unsane/issues"
  },
  "homepage": "https://github.com/mpopv/unsane#readme",
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^25.8.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitest/coverage-v8": "^3.2.7",
    "dompurify": "^3.4.12",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-import": "^2.32.0",
    "fast-check": "^4.9.0",
    "globals": "^15.12.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.8.3",
    "sanitize-html": "^2.17.6",
    "terser": "^5.47.1",
    "tsx": "^4.22.1",
    "typescript": "^5.9.3",
    "vite": "^6.4.3",
    "vitest": "^3.2.7"
  },
  "overrides": {
    "qs": "^6.15.3"
  },
  "bin": {
    "unsane": "./bin/unsane.js"
  }
}
