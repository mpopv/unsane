{
  "name": "unsane",
  "version": "0.0.19",
  "description": "A tiny, zero-dependency, run-anywhere HTML sanitization library written in TypeScript.",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "!dist/test"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "scripts": {
    "build": "npm run clean && tsc && tsc --project tsconfig.cjs.json && npm run build:post",
    "build:post": "node scripts/build-post.mjs",
    "test": "vitest run --coverage",
    "lint": "eslint . --ext .ts,.js",
    "prepare": "npm run build",
    "clean": "rm -rf dist",
    "analyze-size": "tsx measure-size.ts",
    "smoke:package": "node scripts/package-smoke-test.mjs",
    "release:notes": "node scripts/release-notes.mjs",
    "verify:release": "node scripts/post-release-verify.mjs",
    "release": "bin/release.sh"
  },
  "keywords": [
    "html",
    "sanitization",
    "security",
    "typescript"
  ],
  "author": "mpopv <mattpopovich@outlook.com> (https://github.com/mpopv)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mpopv/unsane.git"
  },
  "bugs": {
    "url": "https://github.com/mpopv/unsane/issues"
  },
  "homepage": "https://github.com/mpopv/unsane#readme",
  "engines": {
    "node": ">=18.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "dompurify": "^3.4.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^15.12.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.8.3",
    "sanitize-html": "^2.17.4",
    "terser": "^5.47.1",
    "tsx": "^4.22.1",
    "typescript": "^5.9.3",
    "vite": "^6.4.2",
    "vitest": "^3.2.4"
  },
  "bin": {
    "unsane": "./bin/unsane.js"
  }
}
